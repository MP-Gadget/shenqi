# vim: set ft=make:
#
AR ?= ar
MPICC ?= mpic++
MPICXX ?= mpic++
LOW_PRECISION ?= double

OPTIMIZE ?= -O2 -g -fopenmp -Wall
BOOST_INCL ?=
BOOST_LIBS ?=

ifneq ($(findstring -DUSE_CFITSIO, $(OPT)),)
    # If found, set FITSIO_INCL with the cfitsio flags
    FITSIO_INCL ?= $(shell pkg-config --cflags cfitsio)
    FITSIO_LIBS ?= $(shell pkg-config --libs cfitsio)
endif

# System fftw3, used by the heffte FFT backend. The single precision
# library is not used at runtime but heffte references its symbols.
# fftw3_omp provides the threaded FFT kernels enabled in petapm_module_init;
# it has no pkg-config module of its own.
FFTW_INCL ?= $(shell pkg-config --cflags fftw3 fftw3f)
FFTW_LIBS ?= -lfftw3_omp $(shell pkg-config --libs fftw3 fftw3f)
$(if $(FFTW_LIBS),,$(error fftw3 not found via pkg-config: install fftw-devel or set FFTW_INCL/FFTW_LIBS))

ifneq ($(findstring -DUSE_CUDA, $(OPT)),)
    CUDA_INCL ?= $(shell pkg-config --cflags cudart)
    # cufft for the heffte GPU FFT backend
    CUDA_LIBS ?= $(shell pkg-config --libs cufft cudart)
    NVCC ?= nvcc
    NVOPTIMIZE ?= -O3 -g
endif

# We must have isnan: it is required by the boost interpolation and integration routines
# If we have -ffast-math enabled we must disable finite-math-only manually
OPTIONS = $(OPTIMIZE) $(OPT) -Wall -fno-finite-math-only
#nvcc needs the location of mpi.h, although no MPI calls are made
MPI_INCL = $(shell pkg-config --cflags ompi-c)
NVOPTIONS = -std=c++20 $(NVOPTIMIZE) $(OPT) $(MPI_INCL)
GADGET_TESTDATA_ROOT = $(CURDIR)/../

CFLAGS = $(OPTIONS) $(BOOST_INCL) $(FITSIO_INCL) $(FFTW_INCL) $(CUDA_INCL)
CFLAGS += -I../depends/include
CFLAGS += -I../
CFLAGS += "-DLOW_PRECISION=$(LOW_PRECISION)"
CXXFLAGS = $(CFLAGS)
#Explicitly set C++ standard
CXXFLAGS += -std=gnu++20
#For tests
TCFLAGS = $(CXXFLAGS) -DGADGET_TESTDATA_ROOT=\"$(GADGET_TESTDATA_ROOT)\"

TBB_LIBS := $(shell echo "int main(void){return 0;}" | $(MPICC) -x c++ - -ltbb -o /dev/null 2>/dev/null && echo "-ltbb")
$(if $(TBB_LIBS),,$(warning TBB not found: building without TBB support))
BUNDLEDLIBS = -lbigfile-mpi -lbigfile -lheffte $(TBB_LIBS)
LIBS  = -lm  $(BOOST_LIBS) $(FITSIO_LIBS) $(CUDA_LIBS)
# FFTW_LIBS after libheffte, which references fftw symbols
LIBS += -L../depends/lib $(BUNDLEDLIBS) $(FFTW_LIBS)
V ?= 0

.objs/%.o: %.cpp Makefile $(CONFIG)
	@cmd="$(MPICXX) -MMD -c -o $@ $(CXXFLAGS) $<"; \
	if test "x$(V)" = "x1" ; then echo $$cmd; fi; \
	mkdir -p `dirname $@`; \
	echo Compiling $<; $$cmd

.objs/%.o: %.c Makefile $(CONFIG)
	@cmd="$(MPICC) -MMD -c -o $@ $(CFLAGS) $<"; \
	if test "x$(V)" = "x1" ; then echo $$cmd; fi; \
	mkdir -p `dirname $@`; \
	echo Compiling $<; $$cmd

ifneq ($(findstring -DUSE_CUDA, $(OPT)),)
# Rule to compile .cu files (using nvcc)
.objs/%.o: %.cu Makefile $(CONFIG)
	@cmd="$(NVCC) -MMD -c -o $@ $(NVOPTIONS) -I../depends/include $<"; \
	if test "x$(V)" = "x1" ; then echo $$cmd; fi; \
	mkdir -p `dirname $@`; \
	echo Compiling $<; $$cmd
endif
